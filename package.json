{
	"name": "homy",
	"author": "Kevin Stefanelli",
	"description": "Create specialized agents, assign them capabilities and tools, and define how they interact with one another.",
	"keywords": ["AI", "Agent", "Workflow", "Automatisations", "Tools", "Memories", "A2A"],
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"dev:api": "bun run --filter api dev",
		"dev:web": "bun run --filter web dev",
		"dev:discord": "bun run --filter discord dev",
		"dev": "bun run --filter '*' dev",
		"start:api": "bun run --filter api start",
		"start:discord": "bun run --filter discord start",
		"build": "bun run --workspaces --if-present build",
		"build:api": "bun run --filter api build",
		"build:web": "bun run --filter web build",
		"build:discord": "bun run --filter discord build",
		"typecheck": "bun run --workspaces --if-present typecheck",
		"typecheck:api": "bun run --filter api typecheck",
		"typecheck:web": "bun run --filter web typecheck",
		"typecheck:discord": "bun run --filter discord typecheck",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"db:generate": "bun run --filter api db:generate",
		"db:migrate": "bun run --filter api db:migrate",
		"db:studio": "bun run --filter api db:studio",
		"clean": "bun run --workspaces --if-present clean"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	}
}
