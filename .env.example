# LLM Provider API Keys
# Copy this file to .env and fill in your actual API keys

# Local Lemonade Server
# If using lemonade:* models, set any dummy value for OPENAI_API_KEY
# The actual requests will be routed to http://localhost:13305
# OPENAI_API_KEY=sk-local

# Anthropic Claude models
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT models
OPENAI_API_KEY=sk-...

# Google Gemini models
GEMINI_API_KEY=...

# Groq open models
GROQ_API_KEY=...

# xAI Grok models
XAI_API_KEY=...

# Mistral models
MISTRAL_API_KEY=...


